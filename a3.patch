+int
+settickets(int n)
+{
+  struct proc *p = myproc();
+
+  if(n < 1)
+    return -1;
+
+  acquire(&ptable.lock);
+  p->tickets = n;
+  release(&ptable.lock);
+
+  return 0;
+}
