+void
+getrtimetest(void)
+{
+  int t1, t2;
+
+  printf(1, "getrtime test\n");
+
+  t1 = getrtime();
+  if(t1 < 0){
+    printf(1, "getrtime returned %d\n", t1);
+    exit();
+  }
+
+  for(volatile int i = 0; i < 20000000; i++)
+    ;
+
+  t2 = getrtime();
+  if(t2 < t1){
+    printf(1, "getrtime went backwards: %d -> %d\n", t1, t2);
+    exit();
+  }
+
+  printf(1, "getrtime ok: %d -> %d\n", t1, t2);
+}
