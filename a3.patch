diff --git a/testlottery.c b/testlottery.c
new file mode 100644
index 0000000..0a6d665
--- /dev/null
+++ b/testlottery.c
@@ -0,0 +1,37 @@
+#include "types.h"
+#include "stat.h"
+#include "user.h"
+
+int
+main(void)
+{
+  int pid;
+  int i;
+
+  printf(1, "Parent setting tickets to 10\n");
+  settickets(10);
+
+  for(i = 0; i < 2; i++){
+    pid = fork();
+    if(pid == 0){
+      if(i == 0){
+        printf(1, "Child 1 setting tickets to 1\n");
+        settickets(1);
+      } else {
+        printf(1, "Child 2 setting tickets to 20\n");
+        settickets(20);
+      }
+
+      volatile int j;
+      for(j = 0; j < 100000000; j++);  // CPU work
+
+      printf(1, "Child %d done\n", i+1);
+      exit();
+    }
+  }
+
+  while(wait() > 0);
+
+  printf(1, "All done\n");
+  exit();
+}
