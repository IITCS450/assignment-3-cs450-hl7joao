diff --git a/lotterybench.c b/lotterybench.c
new file mode 100644
index 0000000..57a1a3c
--- /dev/null
+++ b/lotterybench.c
@@ -0,0 +1,54 @@
+#include "types.h"
+#include "stat.h"
+#include "user.h"
+
+static void
+child_run(char *name, int tickets, int duration_ticks)
+{
+  int start_u = uptime();
+  int end_u = start_u + duration_ticks;
+
+  int rt0 = getrtime();
+  settickets(tickets);
+
+  volatile int x = 0;
+  while(uptime() < end_u){
+    x = x + 1;
+  }
+
+  int rt1 = getrtime();
+  int gained = rt1 - rt0;
+
+  printf(1, "%s tickets=%d rtime_gained=%d\n", name, tickets, gained);
+  exit();
+}
+
+int
+main(int argc, char *argv[])
+{
+  int duration = 500;   // increase to 1000+ for smoother ratios
+  int a = 10;
+  int b = 30;
+
+  if(argc >= 2) duration = atoi(argv[1]);
+  if(argc >= 3) a = atoi(argv[2]);
+  if(argc >= 4) b = atoi(argv[3]);
+
+  printf(1, "lotterybench: duration=%d A=%d B=%d\n", duration, a, b);
+
+  int pidA = fork();
+  if(pidA == 0){
+    child_run("Child A", a, duration);
+  }
+
+  int pidB = fork();
+  if(pidB == 0){
+    child_run("Child B", b, duration);
+  }
+
+  wait();
+  wait();
+
+  printf(1, "Done.\n");
+  exit();
+}
